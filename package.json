{
  "name": "founder-daily-brief",
  "version": "1.0.0",
  "description": "Automated daily brief system for founders",
  "main": "dist/index.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --watch --import tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "dry-run": "node --import tsx src/cli/dry-run.ts",
    "generate-brief": "node --import tsx src/cli/generate-brief.ts",
    "import-data": "node --import tsx src/cli/import-data.ts",
    "refresh-docs": "node --import tsx src/cli/refresh-docs.ts",
    "calendar:list": "node --import tsx src/cli/calendar-list.ts",
    "smoke-test": "node --import tsx src/cli/smoke-test.ts",
    "status": "node --import tsx src/cli/status.ts",
    "db:migrate": "node --import tsx src/db/migrate.ts",
    "db:seed": "node --import tsx src/db/seed.ts",
    "db:purge-sample-data": "node --import tsx src/cli/purge-sample-data.ts"
  },
  "keywords": [
    "automation",
    "daily-brief",
    "founder-tools"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^9.2.2",
    "date-fns": "^2.30.0",
    "date-fns-tz": "^2.0.0",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "googleapis": "^131.0.0",
    "imapflow": "^1.2.18",
    "openai": "^4.28.0",
    "twilio": "^4.20.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.16",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
