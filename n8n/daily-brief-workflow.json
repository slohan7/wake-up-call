{
  "name": "Founder Daily Brief",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "30 7 * * *"
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Daily Schedule - 7:30 AM",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [
        260,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ ($env.FOUNDER_DAILY_BRIEF_BASE_URL || 'http://127.0.0.1:3000') + '/webhook/daily-brief' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Webhook-Secret",
              "value": "={{ $env.WEBHOOK_SECRET || '' }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ ({ trigger: 'scheduled', scheduledFor: $now.setZone('America/Detroit').toISO() }) }}",
        "options": {
          "response": {
            "response": {
              "fullResponse": true
            }
          },
          "timeout": 120000
        }
      },
      "id": "trigger-brief-generation",
      "name": "Trigger Brief Generation",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        500,
        300
      ]
    }
  ],
  "connections": {
    "Daily Schedule - 7:30 AM": {
      "main": [
        [
          {
            "node": "Trigger Brief Generation",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "timezone": "America/Detroit",
    "saveDataSuccessExecution": "all",
    "saveDataErrorExecution": "all",
    "saveManualExecutions": true
  },
  "staticData": null,
  "pinData": {},
  "versionId": "2.0.0",
  "tags": [
    {
      "name": "automation",
      "createdAt": "2024-01-01T00:00:00.000Z"
    },
    {
      "name": "daily-brief",
      "createdAt": "2024-01-01T00:00:00.000Z"
    }
  ]
}
