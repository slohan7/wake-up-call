# Core Configuration
# Placeholder credential values are ignored at runtime.
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
TIMEZONE=America/Detroit

# Database
DATABASE_PATH=./data/founder_brief.db

# Google APIs
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback
GOOGLE_REFRESH_TOKEN=your-refresh-token
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_IDS=primary,slohan@umich.edu

# Gmail Configuration
GMAIL_QUERY=is:important OR is:starred OR from:important-sender@example.com
GMAIL_MAX_RESULTS=20

# Proton Mail Bridge / IMAP
# Copy these values from Proton Mail Bridge on your Mac if you want the brief to read Proton mail too.
PROTON_IMAP_HOST=127.0.0.1
PROTON_IMAP_PORT=1143
PROTON_IMAP_SECURE=false
PROTON_IMAP_USERNAME=your-proton-bridge-username
PROTON_IMAP_PASSWORD=your-proton-bridge-password
PROTON_IMAP_MAILBOX=INBOX
PROTON_MAX_RESULTS=20

# Twilio
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890
RECIPIENT_PHONE_NUMBER=+0987654321
APP_BASE_URL=your-public-app-base-url
SMOKE_TEST_SMS_TO=+0987654321
SMOKE_TEST_VOICE_TO=+0987654321

# LLM provider
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-api-key
LLM_MODEL=claude-sonnet-4
LLM_PROVIDER=anthropic

# Feature Flags
ENABLE_VOICE_CALLS=false
ENABLE_SMS=true
DRY_RUN_MODE=false
HIGH_PRIORITY_THRESHOLD=8

# Smoke tests always use live integrations and ignore DRY_RUN_MODE.
# Use the SMOKE_TEST_* numbers to avoid sending smoke-test traffic to the normal daily recipient if needed.
# Set APP_BASE_URL to a publicly reachable app URL if you want Twilio delivery callbacks to update final SMS status.

# Voice Call Configuration
VOICE_CALL_SPEED=1.0
VOICE_CALL_LANGUAGE=en-US
VOICE_CALL_VOICE=Polly.Matthew

# Brief Configuration
MAX_BRIEF_LENGTH=700
MAX_SMS_LENGTH=800
MAX_VOICE_SECONDS=60

# Scheduling
CRON_SCHEDULE=30 7 * * *
SCHEDULE_ENABLED=false

# Webhook URLs (for n8n integration)
WEBHOOK_URL=http://localhost:5678/webhook/daily-brief
WEBHOOK_SECRET=your-webhook-secret
